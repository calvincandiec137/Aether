# ========================================
# GROQ API KEYS
# Get free keys at https://console.groq.com/
# Add multiple keys for higher effective rate limits
# ========================================
GROQ_API_KEY=gsk_your_first_key_here
GROQ_API_KEY_2=gsk_your_second_key_here
GROQ_API_KEY_3=gsk_your_third_key_here
# Add GROQ_API_KEY_4 ... GROQ_API_KEY_10 as needed

# ========================================
# RATE LIMITING
# ========================================
GROQ_DELAY_SECONDS=1.0
MAX_RETRIES=6
RETRY_BACKOFF_FACTOR=2.0

# ========================================
# WEB SEARCH
# ========================================
SEARCH_ENGINE=duckduckgo
MAX_SEARCH_RESULTS=8
MAX_SCRAPED_PAGES_PER_FACTOR=5
SCRAPE_TIMEOUT=15

# ========================================
# DEBATE
# ========================================
DEBATE_ROUNDS=3
MAX_ARGUMENT_LENGTH=200
ALLOW_CROSS_CRITIQUE=true
MAX_FACTORS=5

# ========================================
# OUTPUT
# ========================================
OUTPUT_DIR=outputs/
SAVE_TRANSCRIPTS=true
ENABLE_ANONYMIZATION=true
# Output
OUTPUT_DIR=outputs/
SAVE_TRANSCRIPTS=true
